# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=sports-app

#--------------------------------------------------------------------
# API Keys — client identification (Layer 1 security)
# Generate with: node -e "console.log(require('crypto').randomUUID())"
# Leave blank in local dev to allow all requests without a key.
#--------------------------------------------------------------------
API_KEY_MOBILE=
API_KEY_LANDING=

#--------------------------------------------------------------------
# Rate limiter store
# Options: database (recommended for production), memory (local dev/tests)
#--------------------------------------------------------------------
LIMITER_STORE=database
