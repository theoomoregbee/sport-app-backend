# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Deep links / Universal Links / App Links (optional — leave blank to disable)
APP_SCHEME=courtcheck
APP_IOS_BUNDLE_ID=
APP_IOS_TEAM_ID=
APP_IOS_STORE_URL=
APP_ANDROID_PACKAGE=
APP_ANDROID_SHA256_CERT=
APP_ANDROID_STORE_URL=

# Session
SESSION_DRIVER=cookie

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=sports-app

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000